# App
APP_NAME=Focus Sprint Coach
ENVIRONMENT=local
LOG_LEVEL=INFO

# Database
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=focus_sprint_coach
POSTGRES_HOST=db
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/focus_sprint_coach

# Auth
JWT_SECRET_KEY=change-me
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# LLM (OpenAI-compatible)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=https://api.openai.com/v1

# Observability
POSTHOG_API_KEY=
POSTHOG_HOST=
SENTRY_DSN=

# Build/version
GIT_SHA=
RAILWAY_GIT_COMMIT_SHA=
BUILD_TIME=

# Security
# Comma-separated list, e.g. https://yourdomain.com,https://api.yourdomain.com
CORS_ALLOW_ORIGINS=http://localhost:3000,http://localhost:8000
UI_COOKIE_SECURE=false
UI_COOKIE_SAMESITE=lax

# Billing (Stripe)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PRO=
APP_BASE_URL=http://localhost:8000
